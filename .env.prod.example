# 심사 PC용 — 이 파일을 복사해 .env.prod 로 저장하세요.
#   Windows: copy .env.prod.example .env.prod
#   Linux:   cp .env.prod.example .env.prod

# GHCR 이미지 (팀이 publish-ghcr.ps1 로 push 한 태그와 맞출 것)
SAFE_PROMPT_BACKEND_IMAGE=ghcr.io/buildguardai/safeprompt-guard-v3-backend:latest
SAFE_PROMPT_FRONTEND_IMAGE=ghcr.io/buildguardai/safeprompt-guard-v3-frontend:latest

# 포트 (다른 앱과 충돌 시 변경)
BACKEND_PORT=8001
FRONTEND_PORT=8080

# 호스트 PC의 Ollama (Gemma 문맥 분석, 선택)
OLLAMA_BASE=http://host.docker.internal:11434
GEMMA_MODEL=gemma2:2b
